JWT_SECRET=local-sandbox-test-secret-not-for-production-please-change
NODE_ENV=development
EXECUTION_MODE=dry-run
LIVE_EXECUTION_CONFIRM=NO
DATABASE_URL=file:../server/data/crypto8.db
PORT=8787
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Solana RPC (devnet 기본값)
SOLANA_RPC_URL=https://api.devnet.solana.com
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com

# 운영용 예시(필요할 때만 주석 해제)
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY
# VITE_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY
