VITE_PHANTOM_APP_ID=your-phantom-portal-app-id
# 로컬 개발: 변수를 아예 두지 않으면 프론트가 /api 로 요청(Vite → 8787 프록시)해 세션이 섞이지 않습니다.
# 배포 빌드(GitHub Pages 등)에서는 반드시 실제 API URL을 넣어 빌드하세요.
VITE_API_BASE_URL=http://localhost:8787
# 운영에서는 반드시 랜덤 16자 이상으로 교체. NODE_ENV=production이면 기본값이 거부됩니다.
JWT_SECRET=dev-jwt-secret-change-me
# 액세스 JWT 만료(기본 15m). 로컬에서 줄이려면 예: JWT_ACCESS_EXPIRES_IN=8h
DATABASE_URL="file:../server/data/crypto8.db"
# bcrypt cost factor (10~15, 기본 12). 로컬 테스트 빠르게 하려면 10으로 내릴 수 있음.
# BCRYPT_ROUNDS=12
# CORS 화이트리스트(콤마 구분). 미설정 시 localhost/127.0.0.1 만 허용됩니다.
# CORS_ALLOWED_ORIGINS=https://your-web.example.com,https://staging.example.com
# 프로덕션에서 데모 계정 자동 생성을 강제로 막고 싶을 때 (NODE_ENV=production이면 기본 차단)
# DISABLE_DEMO_USERS=true
# 일별 APY CSV. 미설정 시 server/data/apy_history.csv (번들본)을 사용합니다.
# APY_HISTORY_CSV_PATH=/path/to/apy_history.csv
# 보조 CSV(개발자 로컬 수집본 등). 존재할 때만 사용.
# APY_HISTORY_CSV_FALLBACK_PATH=/path/to/dev_only_apy.csv
EXECUTION_MODE=dry-run
LIVE_EXECUTION_CONFIRM=NO
ARBITRUM_RPC_URL=
ARBITRUM_EXECUTOR_PRIVATE_KEY=
SOLANA_LIVE_RPC_URL=
SOLANA_MAINNET_RPC_URL=
SOLANA_EXECUTOR_PRIVATE_KEY_FILE=
# 운영에서만 허용할 경우에 한해 env 키를 읽습니다.
# SOLANA_EXECUTOR_PRIVATE_KEY=
# ALLOW_INSECURE_ENV_PRIVATE_KEY=true
UNISWAP_SLIPPAGE_BPS=50
UNISWAP_USDC_USDT_FEE_TIER=100
UNISWAP_USDC_USDT_POOL_ADDRESS=0x8c9d230d45f40bbf3d7a7ecf3f77d16f80d3f427
UNISWAP_POOL_MIN_LIQUIDITY=100000
UNISWAP_FULL_RANGE_TICK_LOWER=-887220
UNISWAP_FULL_RANGE_TICK_UPPER=887220
UNISWAP_DEADLINE_SEC=1200
EXECUTION_RETRY_COUNT=3
