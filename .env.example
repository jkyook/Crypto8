# ─────────────────────────────────────────────────────────────────────────────
#  Crypto8 환경변수 설정 예시
#  이 파일을 .env 로 복사하고 실제 값으로 교체하세요.
#  운영 서버(Render 등)에서는 환경변수를 직접 설정하세요.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Phantom 지갑 Portal App ID (Phantom 개발자 콘솔에서 발급)
VITE_PHANTOM_APP_ID=your-phantom-portal-app-id

# 로컬 개발: 빈 값으로 두면 Vite /api 프록시(→ 8787)를 사용합니다.
# 배포 빌드(GitHub Pages 등)에서는 실제 API URL을 넣어 빌드하세요.
# VITE_API_BASE_URL=https://your-api.onrender.com

# ─── Auth ─────────────────────────────────────────────────────────────────────
# JWT 서명 키 (운영: 반드시 랜덤 32자 이상으로 교체)
JWT_SECRET=dev-jwt-secret-change-me-to-32-chars-min

# 액세스 토큰 만료 시간 (기본 15m)
# JWT_ACCESS_EXPIRES_IN=15m

# bcrypt cost factor (기본 12, 로컬 테스트 빠르게 하려면 10)
# BCRYPT_ROUNDS=12

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="file:../server/data/crypto8.db"

# ─── Server ───────────────────────────────────────────────────────────────────
# CORS 화이트리스트 (콤마 구분). 미설정 시 localhost/127.0.0.1 만 허용
# CORS_ALLOWED_ORIGINS=https://your-web.example.com,https://staging.example.com

# 프로덕션에서 데모 계정 자동 생성을 강제 차단 (NODE_ENV=production이면 기본 차단)
# DISABLE_DEMO_USERS=true

# 일별 APY CSV 경로 (미설정 시 server/data/apy_history.csv 번들 사용)
# APY_HISTORY_CSV_PATH=/path/to/apy_history.csv

# ─── 실행 모드 안전장치 ────────────────────────────────────────────────────────
#
# EXECUTION_MODE=dry-run (기본, 절대 변경하지 않을 것)
#   dry-run: 모든 어댑터가 시뮬레이션 결과를 반환합니다. 온체인 실행 없음.
#   live:    LIVE_EXECUTION_CONFIRM=YES + ENABLE_<PROTOCOL>_LIVE=true 가 모두 있어야 실행.
#
EXECUTION_MODE=dry-run

# live 모드를 활성화하려면 YES 로 변경 (두 조건 모두 필요)
LIVE_EXECUTION_CONFIRM=NO

# ─── 프로토콜별 Live 실행 Feature Flag ────────────────────────────────────────
#
# 각 플래그는 EXECUTION_MODE=live + LIVE_EXECUTION_CONFIRM=YES 가 설정된 경우에만 유효합니다.
# 미설정 또는 false 이면 해당 프로토콜은 "unsupported" 상태를 반환합니다.
#
# Aave V3 USDC 공급 (Arbitrum / Base)
ENABLE_AAVE_LIVE=false

# Uniswap V3 LP 민팅 (Arbitrum USDC-USDT 0.01% 풀만 지원)
ENABLE_UNISWAP_LIVE=false

# Orca Whirlpools (공식 SDK 연동 후 활성화 예정)
ENABLE_ORCA_LIVE=false

# Aerodrome Finance (Base 체인, pool/gauge 구조 확인 후 활성화 예정)
ENABLE_AERODROME_LIVE=false

# Raydium AMM (공식 SDK CPMM/CLMM 구분 후 활성화 예정)
ENABLE_RAYDIUM_LIVE=false

# Curve Finance (pool ABI 관리 및 slippage 적용 후 활성화 예정)
ENABLE_CURVE_LIVE=false

# ─── RPC URL 설정 ─────────────────────────────────────────────────────────────
#
# 운영 환경: 전용 RPC provider 사용 (Alchemy, Infura, QuickNode 등)
# 미설정 시 public RPC fallback 사용 (개발용 전용, rate limit 있음)
#
ETHEREUM_RPC_URL=
ARBITRUM_RPC_URL=
BASE_RPC_URL=
SOLANA_RPC_URL=

# ─── Uniswap V3 설정 (ENABLE_UNISWAP_LIVE=true 인 경우 사용) ─────────────────
# Arbitrum executor 지갑 private key (서버 서명 방식 — 향후 클라이언트 서명으로 대체 예정)
ARBITRUM_EXECUTOR_PRIVATE_KEY=

# slippage tolerance in basis points (1bp = 0.01%, 기본 50 = 0.5%)
UNISWAP_SLIPPAGE_BPS=50

# Uniswap V3 풀 fee tier (0.01% = 100, 0.05% = 500, 0.3% = 3000)
UNISWAP_USDC_USDT_FEE_TIER=100

# Arbitrum USDC-USDT 풀 주소 (변경 전 공식 문서 확인 필요)
UNISWAP_USDC_USDT_POOL_ADDRESS=0x8c9d230d45f40bbf3d7a7ecf3f77d16f80d3f427

# 풀 최소 유동성 (이 값 미만이면 live 실행 차단)
UNISWAP_POOL_MIN_LIQUIDITY=100000

# tick 범위 (full range = -887220 ~ 887220)
UNISWAP_FULL_RANGE_TICK_LOWER=-887220
UNISWAP_FULL_RANGE_TICK_UPPER=887220

# tx deadline (초, 기본 1200 = 20분)
UNISWAP_DEADLINE_SEC=1200

# live 실행 1회 최대 금액 (USD)
UNISWAP_MAX_LIVE_DEPOSIT_USD=10000

# ─── Retry 설정 ───────────────────────────────────────────────────────────────
# 어댑터 실패 시 재시도 횟수 (기본 3)
EXECUTION_RETRY_COUNT=3
